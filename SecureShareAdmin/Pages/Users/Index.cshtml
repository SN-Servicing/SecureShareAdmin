@page
@model Snsc.SecureShareAdmin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Manage Users";
}
<h1 class="page-title">Manage Users</h1>

<form method="post" asp-page-handler="Search" class="fieldset-ssi">
    <legend>User Filter</legend>
    <div class="row g-2 align-items-start">
        <div class="col-md-4">
            <label class="form-label form-label-sm" asp-for="EmailSearch">Email</label>
            <input class="form-control form-control-sm" asp-for="EmailSearch"
                   title="All or part of the user's email address (user name)." />
            <div class="form-text">All or part of the user's email address (user name).</div>
        </div>
        <div class="col-md-4">
            <label class="form-label form-label-sm" asp-for="NameSearch">Name</label>
            <input class="form-control form-control-sm" asp-for="NameSearch"
                   title="Search first and last name. Separate multiple terms with spaces." />
            <div class="form-text">Search first and last name. Separate multiple terms with spaces.</div>
        </div>
        <div class="col-auto">
            <label class="form-label form-label-sm">&nbsp;</label>
            <div>
                <button type="submit" class="btn btn-sm btn-ssi">Search</button>
            </div>
        </div>
    </div>
</form>

@if (Model.Users.Count == 0)
{
    <p class="text-muted mt-3">@Model.EmptyMessage</p>
}
else
{
    <table class="table table-sm table-ssi table-ssi-nav mt-3">
        <thead>
            <tr>
                <th>User Name</th>
                <th>Name</th>
                <th>Created</th>
                <th>Disabled?</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>
                    <a class="table-ssi-nav-fill" asp-page="/Users/Edit" asp-route-externalUserId="@user.UserId">@user.UserName</a>
                </td>
                <td>
                    <a class="table-ssi-nav-fill" asp-page="/Users/Edit" asp-route-externalUserId="@user.UserId">@user.Name</a>
                </td>
                <td>
                    <a class="table-ssi-nav-fill" asp-page="/Users/Edit" asp-route-externalUserId="@user.UserId">
                        @(user.CreationDate == DateTime.MinValue ? "\u00A0" : user.CreationDate.ToString("d"))
                    </a>
                </td>
                <td>
                    <a class="table-ssi-nav-fill" asp-page="/Users/Edit" asp-route-externalUserId="@user.UserId">
                        @(string.IsNullOrEmpty(user.Comment) ? "\u00A0" : user.Comment)
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
