@page "{externalUserId:guid}"
@model Snsc.SecureShareAdmin.Pages.Users.EditModel
@{
    ViewData["Title"] = "Edit User";
}
<h1 class="page-title">Edit User Information</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <p class="message-ssi">@Model.Message</p>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.ExternalUser != null)
{
    @foreach (var zone in Model.CurrentZones.Where(z => z.ZonePermissionId > 0))
    {
        <form id="remove-zone-@zone.ZonePermissionId" method="post" asp-page-handler="RemoveZone" class="d-none">
            <input type="hidden" name="zonePermissionId" value="@zone.ZonePermissionId" />
            <input type="hidden" asp-for="ExternalUserId" />
        </form>
    }
    <form id="search-zones-form" method="post" asp-page-handler="SearchZones" class="d-none">
        <input type="hidden" asp-for="ExternalUserId" />
    </form>
    <form id="send-password-reset-form" method="post" asp-page-handler="SendPasswordReset" class="d-none">
        <input type="hidden" asp-for="ExternalUserId" />
    </form>

    <form method="post" asp-page-handler="Save">
        <input type="hidden" asp-for="ExternalUserId" />
        <dl class="row">
            <dt class="col-sm-3">User Name (email)</dt>
            <dd class="col-sm-9">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <span>@Model.ExternalUser.UserName</span>
                    <button type="submit"
                            class="btn btn-outline-secondary btn-sm"
                            form="send-password-reset-form"
                            onclick="return confirm('Send a password reset email to @Model.ExternalUser.UserName?');">
                        Send password reset email
                    </button>
                </div>
            </dd>
            <dt class="col-sm-3">Account Status</dt>
            <dd class="col-sm-9">
                @{
                    ExternalUserDisabledReason? currentReason = Model.DisabledReasons
                        .FirstOrDefault(reason => reason.ExternalUserDisabledReasonId == Model.DisabledReasonId);
                }
                <div class="d-flex flex-wrap align-items-start justify-content-between gap-2">
                    <div id="account-status-summary">
                        @{
                            bool isEnabledStatus = currentReason?.ExternalUserDisabledReasonId == 0;
                        }
                        <span id="account-status-icon"
                              class="ssi-status @(isEnabledStatus ? "ssi-status-ok" : "ssi-status-bad")"
                              aria-hidden="true">@(isEnabledStatus ? "\u2713" : "\u2715")</span>
                        <strong id="account-status-name">@(currentReason?.Name ?? "Unknown")</strong>
                        <span class="text-muted" id="account-status-description">
                            @(string.IsNullOrEmpty(currentReason?.DisplayDescription) ? "" : " — " + currentReason.DisplayDescription)
                        </span>
                    </div>
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            data-bs-toggle="collapse"
                            data-bs-target="#account-status-picker"
                            aria-expanded="false"
                            aria-controls="account-status-picker">
                        Change…
                    </button>
                </div>
                <div class="collapse mt-2" id="account-status-picker">
                    <table class="table table-sm table-ssi table-ssi-reason-pick mb-0">
                        <thead>
                            <tr>
                                <th style="width:2rem;"></th>
                                <th>Name</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var reason in Model.DisabledReasons)
                        {
                            <tr>
                                <td>
                                    <input class="form-check-input"
                                           type="radio"
                                           name="DisabledReasonId"
                                           id="reason-@reason.ExternalUserDisabledReasonId"
                                           value="@reason.ExternalUserDisabledReasonId"
                                           data-reason-name="@reason.Name"
                                           data-reason-description="@reason.DisplayDescription"
                                           data-reason-enabled="@(reason.ExternalUserDisabledReasonId == 0 ? "true" : "false")"
                                           @(Model.DisabledReasonId == reason.ExternalUserDisabledReasonId ? "checked" : null) />
                                </td>
                                <td>
                                    <label class="mb-0" for="reason-@reason.ExternalUserDisabledReasonId">@reason.Name</label>
                                </td>
                                <td>
                                    <label class="mb-0 fw-normal" for="reason-@reason.ExternalUserDisabledReasonId">@reason.DisplayDescription</label>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </dd>
        </dl>
        <div class="row mb-2">
            <div class="col-md-4">
                <label class="form-label" asp-for="FirstName">First Name</label>
                <input class="form-control" asp-for="FirstName" />
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="LastName">Last Name</label>
                <input class="form-control" asp-for="LastName" />
            </div>
            <div class="col-md-4">
                <div class="form-label">Permissions</div>
                <div class="form-check">
                    <input class="form-check-input" asp-for="LoanAccess" id="LoanAccess" />
                    <label class="form-check-label" asp-for="LoanAccess">Loan Access</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" asp-for="SharedFilesAccess" />
                    <label class="form-check-label" asp-for="SharedFilesAccess">Shared Files Access</label>
                </div>
            </div>
        </div>

        <div id="loan-level-access-panel" class="mt-3@(Model.LoanAccess ? "" : " d-none")">
            <partial name="_LoanLevelAccess" model="Model.LoanLevelAccess" />
        </div>

        <h2 class="h6 page-title mt-4">Current Zone Access</h2>
        @if (Model.CurrentZones.Count == 0)
        {
            <p class="text-muted">No zones assigned</p>
        }
        else
        {
            <table class="table table-sm table-ssi">
                <thead><tr><th></th><th>Zone Type</th><th>Description</th><th>Details</th></tr></thead>
                <tbody>
                @foreach (var zone in Model.CurrentZones)
                {
                    <tr>
                        <td>
                            @if (zone.ZonePermissionId > 0)
                            {
                                <button type="submit"
                                        class="btn btn-link btn-sm p-0"
                                        form="remove-zone-@zone.ZonePermissionId"
                                        onclick="return confirm('Are you sure you want to delete this permission?');">
                                    Remove
                                </button>
                            }
                        </td>
                        <td>@zone.ZoneTypeName</td>
                        <td>@zone.Description</td>
                        <td>
                            <partial name="_ZoneIdentifierDetails" model="zone" />
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <h2 class="h6 page-title mt-4">Grant Zone Access</h2>
        <div class="fieldset-ssi">
            <div class="input-group input-group-sm mb-2">
                <input class="form-control" asp-for="ZoneSearchText" form="search-zones-form" placeholder="Search zones" />
                <button class="btn btn-outline-secondary" type="submit" form="search-zones-form">Search</button>
            </div>
            @if (Model.FoundZones.Count > 0)
            {
                <p class="ssi-select-summary message-ssi mb-2"
                   hidden
                   data-ssi-select-one="Click Save to allow access to 1 zone for @Model.ExternalUser.UserName."
                   data-ssi-select-many="Click Save to allow access to {count} zones for @Model.ExternalUser.UserName."></p>
                <table class="table table-sm table-ssi table-ssi-select">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var zone in Model.FoundZones)
                    {
                        bool isSelected = Model.SelectedZoneIds.Contains(zone.ZoneId);
                        <tr>
                            <td>
                                <input type="checkbox"
                                       class="visually-hidden"
                                       name="SelectedZoneIds"
                                       value="@zone.ZoneId"
                                       aria-label="Select zone @zone.Description"
                                       @(isSelected ? "checked" : null) />
                                @zone.ZoneTypeName
                            </td>
                            <td>@zone.Description</td>
                            <td>
                                <partial name="_ZoneIdentifierDetails" model="zone" />
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>

        <div class="d-flex justify-content-between mt-3">
            <a class="btn btn-outline-secondary" asp-page="/Users/Index">&lt;&lt; Users</a>
            <button type="submit" class="btn btn-ssi">Save</button>
        </div>
    </form>
}
