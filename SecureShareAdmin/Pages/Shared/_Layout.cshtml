<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Secure Data Interchange Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-ssi mb-3">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">Secure Data Interchange Admin</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-page="/Users/Index">Users</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Users/Create">Add User</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Zones/Index">Zones</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Zones/Create">Add Zone</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Options/Index">My Options</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Diagnostics/Index">Diagnostics</a></li>
                    </ul>
                    <span class="navbar-text small">@User.Identity?.Name</span>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="footer border-top text-muted">
        <div class="container small">
            &copy; @DateTime.Now.Year - SecureShare Admin
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
