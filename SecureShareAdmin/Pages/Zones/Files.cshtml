@page "{zoneId:int}"
@model Snsc.SecureShareAdmin.Pages.Zones.FilesModel
@{
    ViewData["Title"] = "View Shared Files";
}
<h1 class="page-title">View Shared Files</h1>
<p>Zone: @Model.ZoneDescription</p>

@if (Model.Files.Count == 0)
{
    <p class="text-muted">No files found</p>
}
else
{
    <table class="table table-sm table-ssi">
        <thead>
            <tr>
                <th></th>
                <th>Name</th>
                <th>Description</th>
                <th>Uploaded By</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var file in Model.Files)
        {
            <tr>
                <td>
                    <form method="post" asp-page-handler="Delete">
                        <input type="hidden" name="sharedFileId" value="@file.SharedFileId" />
                        <button type="submit" class="btn btn-link btn-sm p-0"
                                onclick="return confirm('Delete this file?');">Delete</button>
                    </form>
                </td>
                <td>@file.Name</td>
                <td>@file.Description</td>
                <td>@file.UploadedBy</td>
                <td>@file.CreatedOnUtc.ToLocalTime().ToString("g")</td>
            </tr>
        }
        </tbody>
    </table>
}

<p><a asp-page="/Zones/Edit" asp-route-zoneId="@Model.ZoneId">&lt;&lt; Back to Edit Zone</a></p>
